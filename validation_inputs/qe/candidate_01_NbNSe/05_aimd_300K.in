&CONTROL
  nstep = 1000,
  dt = 20.0,
  calculation = 'md',
  prefix = 'candidate_01_NbNSe_aimd',
  pseudo_dir = './pseudos',
  outdir = './tmp',
  tstress = .true.,
  tprnfor = .true.,
/
&SYSTEM
  ibrav = 0,
  nat = 3,
  ntyp = 3,
  ecutwfc = 35,
  ecutrho = 280,
  occupations = 'smearing',
  smearing = 'mp',
  degauss = 0.02,
  assume_isolated = '2D',
/
&ELECTRONS
  conv_thr = 1.0d-7,
  mixing_beta = 0.35,
/
&IONS
  ion_dynamics = 'verlet',
  tempw = 300,
/
&CELL
  cell_dofree = '2Dxy',
/
