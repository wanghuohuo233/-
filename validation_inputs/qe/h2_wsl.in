&CONTROL
 calculation='scf', prefix='h2_wsl', pseudo_dir='./pseudos', outdir='./tmp'
/
&SYSTEM
 ibrav=1, celldm(1)=12.0, nat=2, ntyp=1, ecutwfc=25, ecutrho=200,
 occupations='fixed'
/
&ELECTRONS
 conv_thr=1.0d-6
/
ATOMIC_SPECIES
 H 1.008 H.pbe-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS angstrom
 H 0.0 0.0 0.0
 H 0.0 0.0 0.74
K_POINTS gamma
