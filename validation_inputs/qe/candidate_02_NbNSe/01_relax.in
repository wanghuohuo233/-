&CONTROL
  calculation = 'relax',
  prefix = 'candidate_02_NbNSe',
  pseudo_dir = './pseudos',
  outdir = './tmp',
  tstress = .true.,
  tprnfor = .true.,
/
&SYSTEM
  ibrav = 0,
  nat = 3,
  ntyp = 3,
  ecutwfc = 35,
  ecutrho = 280,
  occupations = 'smearing',
  smearing = 'mp',
  degauss = 0.02,
  assume_isolated = '2D',
/
